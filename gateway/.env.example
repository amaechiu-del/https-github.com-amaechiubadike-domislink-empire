# API Gateway Environment Variables

NODE_ENV=production
PORT=8080
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# Service URLs
HUB_SERVICE_URL=http://hub:3000
REALESTATE_SERVICE_URL=http://realestate:3001
TICKETS_SERVICE_URL=http://tickets:3002
FLIGHTMONITOR_SERVICE_URL=http://flightmonitor:3003
TEACHMASTER_SERVICE_URL=http://teachmaster:3004
ADMIN_SERVICE_URL=http://admin:3005

# Backend Services
AUTH_SERVICE_URL=http://auth-service:4000
PAYMENTS_SERVICE_URL=http://payments-service:4001
GEOLOCATION_SERVICE_URL=http://geolocation-service:4002
NOTIFICATION_SERVICE_URL=http://notification-service:4003

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
