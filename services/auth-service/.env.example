# Auth Service Environment Variables

# Application
NODE_ENV=production
PORT=4000

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-use-strong-random-string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/domislink_auth

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# OAuth Providers (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Logging
LOG_LEVEL=info

# Email Service (for password reset, etc.)
EMAIL_SERVICE_URL=http://notification-service:4003
