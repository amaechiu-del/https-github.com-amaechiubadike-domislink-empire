# Realestate Service Environment Variables

# Application
NODE_ENV=production
PORT=3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# API Gateway
API_GATEWAY_URL=http://gateway:8080

# Authentication Service
AUTH_SERVICE_URL=http://auth-service:4000
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:4000

# Payments Service
PAYMENTS_SERVICE_URL=http://payments-service:4001

# Geolocation Service
GEOLOCATION_SERVICE_URL=http://geolocation-service:4002

# Notification Service
NOTIFICATION_SERVICE_URL=http://notification-service:4003

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/domislink_realestate

# Logging
LOG_LEVEL=info
