{
  "name": "domislink-empire",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:hub": "turbo run dev --filter=hub",
    "dev:realestate": "turbo run dev --filter=realestate",
    "dev:tickets": "turbo run dev --filter=tickets",
    "dev:teachmaster": "turbo run dev --filter=teachmaster",
    "dev:admin": "turbo run dev --filter=admin",
    "dev:flightmonitor": "turbo run dev --filter=flightmonitor"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "turbo": "latest",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "next": "14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "packageManager": "npm@10.0.0"
}