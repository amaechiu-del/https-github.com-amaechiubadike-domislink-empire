# DomisLink Empire - Environment Variables Template
# Copy this file to .env.local in each service/app and fill in your values

# ==============================================
# GLOBAL VARIABLES (Used by multiple services)
# ==============================================

# Supabase (Database & Auth)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# API Gateway
NEXT_PUBLIC_API_GATEWAY_URL=https://api.domislink.com

# ==============================================
# FRONTEND APPS (Next.js)
# ==============================================

# All frontend apps use:
# - NEXT_PUBLIC_SUPABASE_URL
# - NEXT_PUBLIC_SUPABASE_ANON_KEY
# - NEXT_PUBLIC_API_GATEWAY_URL

# Tickets App (additional)
AMADEUS_CLIENT_ID=your_amadeus_client_id
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret

# ==============================================
# AUTH SERVICE (Railway)
# ==============================================

# Server
PORT=3100
NODE_ENV=production

# Supabase
# - Uses SUPABASE_URL
# - Uses SUPABASE_SERVICE_KEY

# CORS
ALLOWED_ORIGINS=https://domislink.com,https://*.domislink.com

# JWT
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# ==============================================
# PAYMENTS SERVICE (Render)
# ==============================================

# Server
PORT=3101
NODE_ENV=production

# Supabase
# - Uses SUPABASE_URL
# - Uses SUPABASE_SERVICE_KEY

# Paystack
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# CORS
# - Uses ALLOWED_ORIGINS

# Webhook
WEBHOOK_SECRET=your_webhook_secret_for_paystack

# ==============================================
# GEOLOCATION SERVICE (Fly.io)
# ==============================================

# Server
PORT=3102
NODE_ENV=production

# Note: Uses free public APIs (ip-api.com, exchangerate-api.com)
# No API keys required for basic usage

# ==============================================
# NOTIFICATIONS SERVICE (Deta Space)
# ==============================================

# Server
PORT=3103
NODE_ENV=production

# Resend (Email Service)
RESEND_API_KEY=your_resend_api_key

# Twilio (SMS - Optional)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone

# ==============================================
# API GATEWAY (Cloudflare Workers)
# ==============================================

# Configure in Cloudflare Dashboard:
# - KV Namespace for rate limiting
# - Custom domain: api.domislink.com
# - Routes to backend services

# Backend service URLs (set in worker.js):
# - auth-api.domislink.com
# - payments-api.domislink.com
# - geo-api.domislink.com
# - notify-api.domislink.com

# ==============================================
# CLOUDFLARE (R2 Storage & Pages)
# ==============================================

CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# R2 Storage
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=domislink-storage

# ==============================================
# MONITORING & LOGGING
# ==============================================

# Better Stack (Logging)
LOGTAIL_TOKEN=your_logtail_source_token

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ==============================================
# CI/CD (GitHub Actions)
# ==============================================

# Vercel
VERCEL_TOKEN=your_vercel_token
VERCEL_ORG_ID=your_vercel_org_id
VERCEL_PROJECT_ID=your_vercel_project_id

# Cloudflare (for deployment)
# - Uses CLOUDFLARE_API_TOKEN
# - Uses CLOUDFLARE_ACCOUNT_ID

# Railway (auto-deploys from GitHub, no token needed)
# Render (auto-deploys from GitHub, no token needed)

# ==============================================
# OPTIONAL INTEGRATIONS
# ==============================================

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Stripe (Alternative payment processor)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# OpenAI (For AI features)
OPENAI_API_KEY=sk-xxxxx

# ==============================================
# NOTES
# ==============================================

# 1. NEVER commit .env files to git
# 2. Use strong, random secrets for JWT_SECRET and WEBHOOK_SECRET
# 3. Rotate API keys regularly
# 4. Use different keys for development and production
# 5. Store production secrets in platform dashboards (Vercel, Railway, etc.)
# 6. Use environment-specific prefixes: NEXT_PUBLIC_ for client-side vars

# ==============================================
# QUICK SETUP CHECKLIST
# ==============================================

