# payments-service Environment Variables

NODE_ENV=production
PORT=4001
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/domislink_payments-service

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
